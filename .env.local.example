# ============================================================
# WX Blueprints — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local no git.
# ============================================================

# --- App URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# --- Firebase (projeto novo: wx-blueprints — SEPARADO do Wally Pet) ---
# Console: https://console.firebase.google.com → Criar projeto "wx-blueprints"
# Project Settings → General → SDK setup and configuration → Config web
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID="wx-blueprints"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# --- Firebase Admin (backend) ---
# Project Settings → Service Accounts → Generate new private key
# Cole o JSON completo em uma única linha (escape quebras de linha com \n)
FIREBASE_SERVICE_ACCOUNT=''
FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# --- Asaas (gateway de pagamento brasileiro) ---
# Painel Asaas → Integrações → Chave API
ASAAS_ENVIRONMENT="sandbox"
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""
ASAAS_CHECKOUT_HOST="https://asaas.com/checkoutSession/show"

# --- Resend (emails transacionais) ---
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="WX Blueprints <noreply@wxdigitalstudio.com.br>"
EMAIL_ADMIN="wxdigitalstudio@gmail.com"

# --- PostHog (analytics) ---
# Dashboard: https://app.posthog.com → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Sentry (monitoramento de erros) ---
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# --- Admin (emails com acesso privilegiado) ---
ADMIN_EMAILS="wxdigitalstudio@gmail.com"
